# ── KiCad auto-saves, backups & locks ─────────────────────────────
#auto_saved_files#
*.bak
*.kicad_sch-bak
*.kicad_pcb-bak
*.sch-bak
*.pcb-bak
*-backups/
_autosave-*
*.autosave
~*.lck
*.lck

# ── KiCad runtime / cache files ───────────────────────────────────
fp-info-cache

# ── External router files (Freerouting) ───────────────────────────
*.dsn
*.ses

# ── Generated reports & logs ──────────────────────────────────────
*.rpt
*.log

# ── 3D model exports at repo root (large, regeneratable from KiCad)
# Patterns anchored with / so EasyEDA.3dshapes/ custom library is NOT ignored
/*.step
/*.obj
/*.mtl
/*.fbx
/*.wrl

# ── DXF exports (regeneratable from PCB editor) ───────────────────
*.dxf

# ── Local KiCad fabrication-toolkit settings ──────────────────────
fabrication-toolkit-options.json

# ── Third-party / system library cache (not project-owned) ────────
Library.pretty/
library/

# ── KiCad plugins & resources (machine-local installs) ────────────
plugins/
resources/

# ── Production folder (generated fabrication files, regeneratable) ─
production/

# ── OS artefacts ──────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor artefacts ──────────────────────────────────────────────
.vscode/
.idea/
